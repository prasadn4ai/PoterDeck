{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.poterdeck.beta",
  "productName": "PoterDeck",
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**/*",
    "api/**/*",
    "lib/**/*",
    "!electron/icons/*.psd"
  ],
  "extraResources": [
    {
      "from": "backend.config.json",
      "to": "backend.config.json"
    },
    {
      "from": "client/dist",
      "to": "client/dist"
    }
  ],
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "electron/icons/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "electron/icons/icon.ico",
    "uninstallerIcon": "electron/icons/icon.ico",
    "installerHeaderIcon": "electron/icons/icon.ico",
    "unicode": true,
    "runAfterFinish": true,
    "include": "electron/installer.nsh"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "electron/icons/icon.icns",
    "category": "public.app-category.productivity"
  }
}
